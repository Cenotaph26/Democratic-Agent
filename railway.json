{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python main.py --mode=$BOT_MODE --capital=$INITIAL_CAPITAL --scan-interval=$SCAN_INTERVAL --tick-interval=$TICK_INTERVAL",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}

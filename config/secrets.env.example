# ── Çalışma Modu ────────────────────────────────
BOT_MODE=testnet          # paper | testnet | live
INITIAL_CAPITAL=10000
SCAN_INTERVAL=60
TICK_INTERVAL=10

# ── Binance API ─────────────────────────────────
# Testnet key: https://testnet.binancefuture.com
BINANCE_API_KEY=buraya_testnet_api_key
BINANCE_API_SECRET=buraya_testnet_api_secret

# ── PostgreSQL ───────────────────────────────────
# Railway'de otomatik enjekte edilir:
DATABASE_URL=postgresql://user:pass@host:5432/db

# ── CryptoPanic ─────────────────────────────────
# Ücretsiz kayıt: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_TOKEN=buraya_cryptopanic_token

# ── Telegram Bildirimleri (İsteğe bağlı) ────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
